{
  "version": 2,
  "installCommand": "echo 'No install needed'",
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "static-site",
  "framework": null,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
